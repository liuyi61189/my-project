# Copy to .env.dev with: powershell -File scripts/init_dev_env.ps1
APP_ENV=development
DEBUG=True
SECRET_KEY=GENERATED_BY_INIT_SCRIPT
ALLOWED_HOSTS=localhost,127.0.0.1

MYSQL_ROOT_PASSWORD=GENERATED_BY_INIT_SCRIPT
MYSQL_DATABASE=testhub_dev
MYSQL_USER=testhub_dev
MYSQL_PASSWORD=GENERATED_BY_INIT_SCRIPT

DB_NAME=testhub_dev
DB_USER=testhub_dev
DB_PASSWORD=GENERATED_BY_INIT_SCRIPT
DB_HOST=mysql
DB_PORT=3306

REDIS_URL=redis://redis:6379/0
CORS_ALLOWED_ORIGINS=http://localhost:18080,http://127.0.0.1:18080
CSRF_TRUSTED_ORIGINS=http://localhost:18080,http://127.0.0.1:18080

EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_USE_TLS=False
EMAIL_USE_SSL=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=testhub-dev@localhost

DEV_FRONTEND_PORT=18080
DEV_BACKEND_PORT=18000
DEV_MYSQL_PORT=13306
