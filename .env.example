# ========== 数据库配置 ==========
MYSQL_ROOT_PASSWORD=change-me-to-strong-password
MYSQL_DATABASE=testhub
MYSQL_USER=testhub
MYSQL_PASSWORD=change-me-to-strong-password

# ========== Django 配置 ==========
SECRET_KEY=generate-a-new-secret-key-here
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# ========== 数据库连接 ==========
DB_NAME=testhub
DB_USER=testhub
DB_PASSWORD=change-me-to-strong-password
DB_HOST=mysql
DB_PORT=3306

# ========== Redis / Celery ==========
REDIS_URL=redis://default@redis:6379/0

# ========== CORS / CSRF ==========
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
CSRF_TRUSTED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# ========== 邮件配置 ==========
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=webmaster@localhost
